# Copy this file to .env (or set these in your shell / launcher).
# config/secrets.py reads these on import. Never commit a real .env.

# --- Admin dashboard ---------------------------------------------------------
# Read once on first boot and persisted (bcrypt-hashed) into server/auth_state.json.
ADMIN_USER=bishnu
ADMIN_PASS=Bishnu1550

# Set to true when serving the dashboard behind HTTPS.
# Marks the session cookie Secure + SameSite=strict.
AJA_HTTPS=false

# --- LinkedIn credentials ----------------------------------------------------
LINKEDIN_USER=
LINKEDIN_PASS=

# --- LLM provider ------------------------------------------------------------
# "true" / "false"
USE_AI=true

# "openai" | "deepseek" | "gemini"
AI_PROVIDER=openai

# Trailing slash matters for openai-compatible endpoints.
# Examples: https://api.openai.com/v1/  |  http://127.0.0.1:1234/v1/
#           https://api.deepseek.com/v1
LLM_API_URL=https://api.openai.com/v1/

# "not-needed" for Ollama; real key otherwise.
LLM_API_KEY=

# "gpt-4o-mini", "gpt-4o", "gemini-1.5-flash", "deepseek-llm:latest", etc.
LLM_MODEL=gpt-4o-mini

# "openai" | "openai-like" | "deepseek" | "gemini"
LLM_SPEC=openai

# Stream tokens from the LLM? "true" / "false".
STREAM_OUTPUT=false
